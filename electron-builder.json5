// @see - https://www.electron.build/configuration/configuration
// JojoClient is Windows-only. macOS and Linux targets are intentionally omitted —
// Java auto-detection, runtime install paths, and the launch pipeline have not
// been validated on those platforms. Re-add targets only after porting.
{
  "$schema": "https://raw.githubusercontent.com/electron-userland/electron-builder/master/packages/app-builder-lib/scheme.json",
  "appId": "com.jojoclient.app",
  "asar": true,
  "productName": "JojoClient",
  // App icon: 512x512 PNG generated from icon.svg at build time.
  // Run: npx sharp-cli -i public/icon.svg -o public/icon.png resize 512 512
  "icon": "public/icon.png",
  "publish": {
    "provider": "github",
    "owner": "Jonas1903",
    "repo": "JojoClient",
    "releaseType": "release"
  },
  "directories": {
    "output": "release/${version}"
  },
  "files": [
    "dist",
    "dist-electron"
  ],
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": [
          "x64"
        ]
      }
    ],
    "artifactName": "${productName}-Windows-${version}-Setup.${ext}"
  },
  "nsis": {
    "oneClick": false,
    "perMachine": false,
    "allowToChangeInstallationDirectory": true,
    "deleteAppDataOnUninstall": false
  }
}
